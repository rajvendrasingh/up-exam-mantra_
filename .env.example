# Firebase Configuration
# Copy this file to .env and fill in your Firebase project details

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Gemini AI API Key for Guru Chatbot
# Get your free API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# SendGrid API Key for Email Service
# Get your free API key from: https://sendgrid.com
# Free tier: 100 emails/day
VITE_SENDGRID_API_KEY=your_sendgrid_api_key_here

# Instructions:
# 1. Go to https://console.firebase.google.com/
# 2. Create a new project
# 3. Add a web app
# 4. Copy the config values here
# 5. Get SendGrid API key from https://sendgrid.com
# 6. Rename this file to .env
